# Wails build output (regenerated by `wails build`)
/build

# Frontend build output (keep the .gitkeep so the go:embed compiles on a fresh
# clone before any build)
/frontend/dist/*
!/frontend/dist/.gitkeep
/frontend/node_modules
/frontend/package.json.md5

# Wails-generated bindings (regenerated by `wails dev` / `wails generate module`)
/frontend/wailsjs
